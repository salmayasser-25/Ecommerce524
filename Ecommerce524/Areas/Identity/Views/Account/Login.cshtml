@model Ecommerce524.ViewModel.LoginVM

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h2 class="mb-0">Welcome Back!</h2>
                    <p class="mb-0 mt-2">Sign in to your account</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Email or Username -->
                        <div class="mb-4">
                            <label asp-for="EmailOrUserName" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-user"></i>
                                </span>
                                <input asp-for="EmailOrUserName" class="form-control" placeholder="Enter email or username" />
                            </div>
                            <span asp-validation-for="EmailOrUserName" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-lock"></i>
                                </span>
                                <input asp-for="Password" class="form-control" placeholder="Enter password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="RememberMe" />
                                <label class="form-check-label" asp-for="RememberMe">
                                    @Html.DisplayNameFor(model => model.RememberMe)
                                </label>
                            </div>
                            <div>
                                <a asp-action="ForgotPassword" class="text-primary text-decoration-none small">
                                    <i class="fas fa-key me-1"></i>Forgot Password?
                                </a>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Sign In
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-3">
                    <div class="small">
                        <a asp-action="Register" class="text-primary text-decoration-none">
                            <i class="fas fa-user-plus me-1"></i>Don't have an account? Sign up
                        </a>
                    </div>
                    <div class="small mt-2">
                        <a asp-action="Index" asp-controller="Home" asp-area="Customer" class="text-secondary text-decoration-none">
                            <i class="fas fa-home me-1"></i>Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}