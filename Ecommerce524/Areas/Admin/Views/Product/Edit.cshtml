@model Ecommerce524.Models.Product

@{
    var categories = ViewBag.Categories;
    var brands = ViewBag.Brands;
}

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Edit Product</h2>
        </div>
    </div>
</div>

<div class="row my-3">
    <div class="col-12">

        <form method="post" enctype="multipart/form-data">

            <!-- hidden id -->
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <input class="form-control" name="Name" value="@Model.Name">
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="Description">@Model.Description</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Main Image</label>

                <br />
                <img id="previewImg" src="~/img/Product/@Model.MainImg" width="150" class="mb-2" />

                <input type="file" class="form-control" name="MainImg" id="imageInput">
            </div>
            <div class="mb-3">
                <label class="form-label">Sub Images</label>

                <div class="d-flex flex-wrap gap-3">

                    @foreach (var img in Model.SubImages)
                    {
                        <div style="position:relative">

                            <img src="~/img/Product/Sub/@img.SubImg"
                                 width="120"
                                 style="border-radius:10px" />

                            <a asp-action="DeleteSubImage"
                               asp-route-id="@img.Id"
                               class="btn btn-danger btn-sm"
                               style="position:absolute; top:5px; right:5px">
                                X
                            </a>

                        </div>
                    }

                </div>
                
            </div>

            <div class="mb-3">
                <label>Add New Sub Images</label>
                <input type="file" name="SubImgs" multiple class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Price</label>
                <input class="form-control" name="price" value="@Model.price">
            </div>

            <div class="mb-3">
                <label class="form-label">Discount</label>
                <input class="form-control" name="Discount" value="@Model.Discount">
            </div>

            <div class="mb-3">
                <label class="form-label">Quantity</label>
                <input class="form-control" name="Quantity" value="@Model.Quantity">
            </div>

            <div class="mb-3">
                <label class="form-label">Rate</label>
                <input class="form-control" name="Rate" value="@Model.Rate">
            </div>

            <!-- Category -->
            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" name="CategoryId">
                    @foreach (var item in categories)
                    {
                        if (Model.CategoryId == item.Id)
                        {
                            <option value="@item.Id" selected>@item.Name</option>
                        }
                        else
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <!-- Brand -->
            <div class="mb-3">
                <label class="form-label">Brand</label>
                <select class="form-select" name="BrandId">
                    @foreach (var item in brands)
                    {
                        if (Model.BrandId == item.Id)
                        {
                            <option value="@item.Id" selected>@item.Name</option>
                        }
                        else
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label class="form-label">Status</label>
                <select name="Status" class="form-select">

                    @if (Model.Status)
                    {
                        <option value="true" selected>Active</option>
                        <option value="false">Inactive</option>
                    }
                    else
                    {
                        <option value="true">Active</option>
                        <option value="false" selected>Inactive</option>
                    }

                </select>
            </div>

            <button type="submit" class="btn btn-warning">Update</button>

        </form>

    </div>
</div>
<script>

    document.getElementById("imageInput").addEventListener("change", function () {

        const file = this.files[0];

        if (file) {

            const preview = document.getElementById("previewImg");

            preview.src = URL.createObjectURL(file);

        }

    });

</script>