
@model Ecommerce524.ViewModel.ProductsVM
<div class="" container-fluid px-4"">

    <div class="row align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6 mb-0">All Products </h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Admin/Product/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create</a>
        </div>
    </div>


    <div class="row mb-3">
        <div class="col-12 p-3" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
            <form>
                <div class="row g-2">
                    <!--product name-->
                    <div class="col-md-2">
                        <input type="text" class="form-control" placeholder="Name" name="name" value="@Model.productFilterVM.Name" />
                    </div>
                    <!--Min price-->
                    <div class="col-md-2">
                        <input type="text" class="form-control" placeholder="Min Price" name="MinPrice" value="@Model.productFilterVM.MinPrice" />
                    </div>
                    <!--Max price-->
                    <div class="col-md-2">
                        <input type="text" class="form-control" placeholder="Max Price" name="maxPrice" value="@Model.productFilterVM.MaxPrice" />
                    </div>
                    <!--category-->
                    <div class="col-md-2">
                        <select name="CategoryId" class="form-select" >
                            @* <option selected>select category</option> *@
                            <option >--select Category--</option>
                            @foreach(var item in Model.Categories)
                            {
                                if (Model.productFilterVM.CategoryId==item.Id)
                                {
                                    <option value="@item.Id" selected>@item.Name</option>

                                }
                                else
                                {
                                    <option value="@item.Id">@item.Name</option>

                                }
                                
                            }
                        </select>
                    </div>
                    <!--Brand-->
                    <div  class="col-md-2">
                        <select name="BrandId" class="form-select">
                            @* <option selected>select Brand</option> *@
                            <option >--select Brand--</option>
                            @foreach (var item in Model.Brands)
                            {
                                if (Model.productFilterVM.BrandId == item.Id)
                                {
                                    <option value="@item.Id" selected>@item.Name</option>

                                }
                                else
                                {
                                    <option value="@item.Id">@item.Name</option>

                                }
                            }
                        </select>
                    </div>
                    <!--quantity-->
                    <div class="col-md-2 form-check">
                        <input type="checkbox" id="lessQuantity" class="form-check-input" name="lessQuantity" value="true"/>
                        <label for="lessQuantity">less Quantity</label>
                    </div>
                    <!--Submit button-->
                    <div class="col-md-2 mt-3">
                        <button type="submit" class="btn btn-dark w-100">Filter</button>
                    </div>
                </div>
            </form>
        </div>
    </div>


    <div class="row">
        <div class="col-12">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Name</th>
                        <th scope="col">Price</th>
                        <th scope="col">Quantity</th>
                        <th scope="col">Rate</th>
                        <th scope="col">Category</th>
                        <th scope="col">Brand</th>
                        <th scope="col">Status</th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <th scope="row">@item.Id</th>
                            <td>@item.Name</td>
                            <td>@item.price.ToString("c")</td>
                            @if (item.Quantity > 0 && item.Quantity < 50)
                            {
                                <td><span class="badge text-bg-danger">@item.Quantity</span></td>
                            }
                            else if (item.Quantity >= 50 && item.Quantity < 100)
                            {
                                <td><span class="badge text-bg-warning">@item.Quantity</span></td>
                            }
                            else
                            {
                                <td><span class="badge text-bg-info">@item.Quantity</span></td>

                            }
                            <td>@item.Rate of(5)</td>
                            <td><span class="badge text-bg-secondary">@item.Category.Name</span></td>
                            <td><span class="badge text-bg-secondary">@item.Brand.Name</span></td>
                            @if (item.Status == true)
                            {
                                <td><span class="badge text-bg-success">Active</span></td>
                            }
                            else
                            {
                                <td><span class="badge text-bg-danger">Inactive</span></td>
                            }
                            <td>
                                <a href="/Admin/Product/Details/@item.Id" type="button" class="btn btn-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a href="/Admin/Product/Edit/@item.Id" type="button" class="btn btn-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                <a href="/Admin/Product/Delete/@item.Id"
                                   class="btn btn-danger btn-sm btn-delete">
                                    <i class="bi bi-trash"></i>
                                </a>

                                


                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Product/Index?page=@(Model.CurrentPage - 1)">Previous</a></li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><a class="page-link" href="/Admin/Product/Index?page=@i">@i</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="/Admin/Product/Index?page=@i">@i</a></li>
                        }
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Product/Index?page=@(Model.CurrentPage + 1)">Next</a></li>
                    }

                </ul>
            </nav>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault(); // stop normal navigation

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then(result => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: "Deleted!",
                            text: "Your file has been deleted.",
                            icon: "success"
                        }).then(() => {
                            // Redirect to delete URL after success message
                            window.location.href = url;
                        });
                    }
                });
            });
        });
    });
</script>