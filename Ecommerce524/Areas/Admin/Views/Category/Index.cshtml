@* @model IEnumerable<Categories> *@
@model Ecommerce524.ViewModel.CategoriesVM
<div class="" container-fluid px-4"">
    
    <div class="row align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6 mb-0">All Category </h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Admin/Category/create" class="btn btn-success">Create</a>  
        </div>
    </div>

    
    <div class="row mb-3">
        <div class="col-12 p-3" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
            <form>
                <div class="row g-2">
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="name" name="name" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-dark w-100">Filter</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    
    <div class="row">
        <div class="col-12">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Name</th>
                        <th scope="col">Status</th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Category)
                    {
                        <tr>
                            <th scope="row">@item.Id</th>
                            <td>@item.Name</td>
                            @if (item.Status == true)
                            {
                                <td><span class="badge text-bg-success">Active</span></td>
                            }
                            else
                            {
                                <td><span class="badge text-bg-danger">Inactive</span></td>
                            }
                            <td>
                                <a href="/Admin/Category/Edit/@item.Id" type="button" class="btn btn-warning btn-sm">Edit</a>
                                <a href="/Admin/Category/Delete/@item.Id" class="btn btn-danger btn-sm btn-delete">Delete</a>
                                
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-center">
                   @if(Model.CurrentPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Category/Index?page=@(Model.CurrentPage - 1)">Previous</a></li>
                    }
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if(i == Model.CurrentPage)
                        {
                            <li class="page-item active"><a class="page-link" href="/Admin/Category/Index?page=@i">@i</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="/Admin/Category/Index?page=@i">@i</a></li>
                        }
                    }
                    @if(Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Category/Index?page=@(Model.CurrentPage + 1)">Next</a></li>
                    }

                </ul>
            </nav>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault(); // stop normal navigation

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then(result => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: "Deleted!",
                            text: "Your file has been deleted.",
                            icon: "success"
                        }).then(() => {
                            // Redirect to delete URL after success message
                            window.location.href = url;
                        });
                    }
                });
            });
        });
    });
</script>